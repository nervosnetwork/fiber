meta {
  name: wait channel ready between node1 and node3
  type: http
  seq: 4
}

post {
  url: {{CKB_RPC_URL}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "id": "42",
    "jsonrpc": "2.0",
    "method": "generate_epochs",
    "params": ["0x1"]
  }
}

assert {
  res.status: eq 200
}

script:post-response {
  const axios = require("axios");

  const txHash = bru.getVar("EXTERNAL_FUNDING_TX_HASH");
  const channelId = bru.getVar("EXTERNAL_FUNDING_CHANNEL_ID");

  if (!txHash) {
    throw new Error("Assertion failed: missing EXTERNAL_FUNDING_TX_HASH before waiting channel ready");
  }

  if (!channelId) {
    throw new Error("Assertion failed: missing EXTERNAL_FUNDING_CHANNEL_ID before waiting channel ready");
  }

  if (res.body.error) {
    throw new Error(`Assertion failed: generate_epochs failed before ready check: ${res.body.error.message}`);
  }

  console.log("[external-funding-open] generated one epoch before checking ChannelReady");
  await new Promise((r) => setTimeout(r, 5000));

  const txResp = await axios.post(
    bru.getEnvVar("CKB_RPC_URL"),
    {
      id: "external-funding-funding-tx-commit-check",
      jsonrpc: "2.0",
      method: "get_transaction",
      params: [txHash],
    },
    {
      headers: { "Content-Type": "application/json", Accept: "application/json" },
    },
  );

  if (txResp.data && txResp.data.error) {
    throw new Error(
      `Assertion failed: get_transaction failed while checking channel ready: ${txResp.data.error.message}`,
    );
  }

  const txStatus =
    txResp.data && txResp.data.result && txResp.data.result.tx_status && txResp.data.result.tx_status.status;

  if (txStatus !== "committed") {
    throw new Error(
      `Assertion failed: funding tx ${txHash} not committed after one epoch, last_status=${String(txStatus)}`,
    );
  }

  const node3Resp = await axios.post(
    bru.getEnvVar("NODE3_RPC_URL"),
    {
      id: "external-funding-node3-ready-check",
      jsonrpc: "2.0",
      method: "list_channels",
      params: [{ pubkey: bru.getEnvVar("NODE1_PUBKEY") }],
    },
    {
      headers: { "Content-Type": "application/json", Accept: "application/json" },
    },
  );

  if (node3Resp.data && node3Resp.data.error) {
    throw new Error(
      `Assertion failed: node3 list_channels failed while checking ready state: ${node3Resp.data.error.message}`,
    );
  }

  const node3Channels = (node3Resp.data && node3Resp.data.result && node3Resp.data.result.channels) || [];
  const node3Channel = node3Channels.find((item) => item.channel_id === channelId);
  const node3State = node3Channel && node3Channel.state && node3Channel.state.state_name;

  if (node3State !== "ChannelReady") {
    throw new Error(
      `Assertion failed: node3 channel not ready after one epoch, channel_id=${channelId}, last_state=${String(node3State)}`,
    );
  }

  bru.setVar("CHANNEL_READY", "true");
  console.log(`[external-funding-open] channel is ready on node1 and node3: ${channelId}`);
}
