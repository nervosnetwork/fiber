meta {
  name: check node1 node2 node3 balances after submit
  type: http
  seq: 5
}

post {
  url: {{CKB_RPC_URL}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "id": 42,
    "jsonrpc": "2.0",
    "method": "get_cells_capacity",
    "params": [
      {
        "script_type": "lock",
        "script": {}
      }
    ]
  }
}

script:pre-request {
  const script = bru.getVar("NODE2_FUNDING_SCRIPT");
  const body = req.getBody();
  body.params[0].script = script;
  req.setBody(body);
}

assert {
  res.body.error: isUndefined
  res.body.result.capacity: isDefined
}

script:post-response {
  const axios = require("axios");

  if (bru.getVar("CHANNEL_READY") !== "true") {
    throw new Error("Assertion failed: channel is not marked ready before balance checks");
  }

  async function getCapacity(nodeLabel, scriptVar, requestId) {
    const script = bru.getVar(scriptVar);
    if (!script) {
      throw new Error(`Assertion failed: missing ${scriptVar} for ${nodeLabel} balance check`);
    }

    const resp = await axios.post(
      bru.getEnvVar("CKB_RPC_URL"),
      {
        id: requestId,
        jsonrpc: "2.0",
        method: "get_cells_capacity",
        params: [
          {
            script_type: "lock",
            script: script
          }
        ]
      },
      {
        headers: { "Content-Type": "application/json", Accept: "application/json" }
      }
    );

    if (resp.data && resp.data.error) {
      throw new Error(
        `Assertion failed: get_cells_capacity failed for ${nodeLabel}: ${resp.data.error.message}`,
      );
    }

    const capacity = resp.data && resp.data.result && resp.data.result.capacity;
    if (capacity === undefined) {
      throw new Error(
        `Assertion failed: get_cells_capacity has no result.capacity for ${nodeLabel}, response=${JSON.stringify(resp.data)}`,
      );
    }

    return BigInt(capacity);
  }

  const capacity = res.body && res.body.result && res.body.result.capacity;
  if (capacity === undefined) {
    throw new Error(
      `Assertion failed: get_cells_capacity has no result.capacity, response=${JSON.stringify(res.body)}`,
    );
  }

  const node1Before = BigInt(bru.getVar("NODE1_BALANCE_BEFORE"));
  const node2Before = BigInt(bru.getVar("NODE2_BALANCE_BEFORE"));
  const node3Before = BigInt(bru.getVar("NODE3_BALANCE_BEFORE"));
  const node1After = await getCapacity("node1", "NODE1_FUNDING_SCRIPT", "external-funding-node1-balance-after-submit");
  const node2After = BigInt(capacity);
  const node3After = await getCapacity("node3", "NODE3_FUNDING_SCRIPT", "external-funding-node3-balance-after-submit");
  const node1Diff = node1After - node1Before;
  const node2Diff = node2After - node2Before;
  const node3Diff = node3After - node3Before;
  const fundingAmount = BigInt(bru.getVar("EXTERNAL_FUNDING_AMOUNT"));
  const node3ExpectedSpent = BigInt("9900000000");
  const node3MinSpent = BigInt("9800000000");
  const node3MaxSpent = BigInt("10000000000");

  bru.setVar("NODE1_BALANCE_AFTER", node1After.toString());
  bru.setVar("NODE2_BALANCE_AFTER", node2After.toString());
  bru.setVar("NODE3_BALANCE_AFTER", node3After.toString());
  console.log(
    `[external-funding-open] Node1 balance: before=${node1Before} after=${node1After} diff(after-before)=${node1Diff}`,
  );
  console.log(
    `[external-funding-open] Node2 balance: before=${node2Before} after=${node2After} diff(after-before)=${node2Diff}`,
  );
  console.log(
    `[external-funding-open] Node3 balance: before=${node3Before} after=${node3After} diff(after-before)=${node3Diff} expected_spent~${node3ExpectedSpent}`,
  );

  // Check node1
  if (node1After !== node1Before) {
    throw new Error(
      `Assertion failed: node1 balance should remain unchanged, before=${node1Before}, after=${node1After}`,
    );
  }

  // Check node2
  if (node2After > node2Before) {
    throw new Error(
      `Assertion failed: node2 balance should not increase after submit, before=${node2Before}, after=${node2After}`,
    );
  }

  const node2Spent = node2Before - node2After;
  if (node2Spent === BigInt(0)) {
    throw new Error(
      `Assertion failed: channel ready but node2 balance unchanged, before=${node2Before}, after=${node2After}`,
    );
  }

  if (node2Spent < fundingAmount) {
    throw new Error(
      `Assertion failed: expected node2 spent amount >= funding amount, spent=${node2Spent}, funding_amount=${fundingAmount}`,
    );
  }

  // Check node3
  if (node3After >= node3Before) {
    throw new Error(
      `Assertion failed: node3 balance should decrease after auto-accept, before=${node3Before}, after=${node3After}`,
    );
  }

  const node3Spent = node3Before - node3After;
  if (node3Spent < node3MinSpent || node3Spent > node3MaxSpent) {
    throw new Error(
      `Assertion failed: expected node3 spent amount to be around 100 CKB, spent=${node3Spent}, expected_range=[${node3MinSpent}, ${node3MaxSpent}], expected_target=${node3ExpectedSpent}`,
    );
  }
}
