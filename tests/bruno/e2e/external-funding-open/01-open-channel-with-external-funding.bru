meta {
  name: Node1 open channel with external funding to Node3
  type: http
  seq: 1
}

post {
  url: {{NODE1_RPC_URL}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "id": "42",
    "jsonrpc": "2.0",
    "method": "open_channel_with_external_funding",
    "params": [
      {
        "pubkey": "{{NODE3_PUBKEY}}",
        "funding_amount": "0xba43b7400",
        "public": true,
        "shutdown_script": {},
        "funding_lock_script": {}
      }
    ]
  }
}

vars:post-response {
  max_open_attempts: 7
}

script:pre-request {
  const axios = require("axios");

  const DEFAULT_FUNDING_AMOUNTS = [
    "0x8bb2c9700",
    "0x6fc23ac00",
    "0x5d21dba00",
    "0x4a817c800",
    "0x37e11d600",
    "0x2540be400",
    "0x12a05f200",
  ];

  async function rpc(url, body) {
    const resp = await axios.post(url, body, {
      headers: { "Content-Type": "application/json", Accept: "application/json" },
    });
    if (resp.data && resp.data.error) {
      throw new Error(`Assertion failed: RPC ${body.method} failed on ${url}: ${resp.data.error.message}`);
    }
    return resp.data && resp.data.result;
  }

  async function loadFundingContext(nodeLabel, nodeRpcUrl, balanceVar, scriptVar) {
    const nodeInfo = await rpc(nodeRpcUrl, {
      id: `external-funding-${nodeLabel}-info`,
      jsonrpc: "2.0",
      method: "node_info",
      params: [],
    });
    const script = nodeInfo && nodeInfo.default_funding_lock_script;
    if (!script) {
      throw new Error(`Assertion failed: ${nodeLabel} default_funding_lock_script is missing`);
    }

    const balanceResult = await rpc(bru.getEnvVar("CKB_RPC_URL"), {
      id: `external-funding-${nodeLabel}-balance`,
      jsonrpc: "2.0",
      method: "get_cells_capacity",
      params: [
        {
          script_type: "lock",
          script,
        },
      ],
    });
    const capacity = balanceResult && balanceResult.capacity;
    if (capacity === undefined) {
      throw new Error(`Assertion failed: ${nodeLabel} balance capacity is missing`);
    }

    bru.setVar(scriptVar, script);
    bru.setVar(balanceVar, capacity);
  }

  async function ensurePeerConnected() {
    const node1RpcUrl = bru.getEnvVar("NODE1_RPC_URL");
    const node3Addr = bru.getEnvVar("NODE3_ADDR");

    try {
      await rpc(node1RpcUrl, {
        id: "external-funding-connect-node1-node3",
        jsonrpc: "2.0",
        method: "connect_peer",
        params: [{ address: node3Addr }],
      });
    } catch (err) {
      const message = String(err && err.message ? err.message : err);
      if (!message.includes("Peer already connected")) {
        throw err;
      }
    }

    // Dialing is async. Give the connection a moment before opening the channel.
    await new Promise((r) => setTimeout(r, 1000));
  }

  if (bru.getVar("EXTERNAL_FUNDING_INIT_DONE") !== "1") {
    await ensurePeerConnected();
    await loadFundingContext("node1", bru.getEnvVar("NODE1_RPC_URL"), "NODE1_BALANCE_BEFORE", "NODE1_FUNDING_SCRIPT");
    await loadFundingContext("node2", bru.getEnvVar("NODE2_RPC_URL"), "NODE2_BALANCE_BEFORE", "NODE2_FUNDING_SCRIPT");
    await loadFundingContext("node3", bru.getEnvVar("NODE3_RPC_URL"), "NODE3_BALANCE_BEFORE", "NODE3_FUNDING_SCRIPT");
    bru.setVar("EXTERNAL_FUNDING_INIT_DONE", "1");
  }

  const fixedFundingAmount = bru.getEnvVar("EXTERNAL_FUNDING_AMOUNT");
  const openAttemptIndex = bru.getVar("external_funding_open_attempt_index") || 0;
  const fundingAmount = fixedFundingAmount || DEFAULT_FUNDING_AMOUNTS[openAttemptIndex];
  const script = bru.getVar("NODE2_FUNDING_SCRIPT");
  const body = req.getBody();
  body.params[0].funding_amount = fundingAmount;
  body.params[0].shutdown_script = script;
  body.params[0].funding_lock_script = script;
  req.setBody(body);
  bru.setVar("EXTERNAL_FUNDING_AMOUNT", fundingAmount);
}

assert {
  res.status: eq 200
}

script:post-response {
  const fixedFundingAmount = bru.getEnvVar("EXTERNAL_FUNDING_AMOUNT");
  if (res.body.error) {
    if (fixedFundingAmount) {
      throw new Error(
        `open_channel_with_external_funding failed with EXTERNAL_FUNDING_AMOUNT=${fixedFundingAmount}: ${res.body.error.message}`,
      );
    }

    const i = bru.getVar("external_funding_open_attempt_index") || 0;
    const n = bru.getVar("max_open_attempts");
    if (i + 1 < n) {
      bru.setVar("external_funding_open_attempt_index", i + 1);
      console.log(
        `[external-funding-open] open failed with funding_amount=${bru.getVar("EXTERNAL_FUNDING_AMOUNT")}, retry ${i + 1}/${n}: ${res.body.error.message}`,
      );
      bru.setNextRequest("Node1 open channel with external funding to Node3");
      return;
    }

    throw new Error(
      `open_channel_with_external_funding failed for all candidate amounts, last error: ${res.body.error.message}`,
    );
  }

  const tx = res.body.result.unsigned_funding_tx;
  if (!tx.outputs || tx.outputs.length === 0) {
    throw new Error("Assertion failed: unsigned_funding_tx.outputs should not be empty");
  }
  bru.setVar("external_funding_open_attempt_index", 0);
  bru.setVar("EXTERNAL_FUNDING_CHANNEL_ID", res.body.result.channel_id);
  bru.setVar("EXTERNAL_FUNDING_UNSIGNED_TX", tx);
}
