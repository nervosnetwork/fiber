meta {
  name: list node1 channels before submit signed tx
  type: http
  seq: 9
}

post {
  url: {{NODE1_RPC_URL}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "id": "42",
    "jsonrpc": "2.0",
    "method": "list_channels",
    "params": [
      {
        "pubkey": "{{NODE3_PUBKEY}}"
      }
    ]
  }
}

assert {
  res.body.error: isUndefined
  res.body.result.channels: isDefined
}

script:post-response {
  const channels = res.body.result.channels || [];
  const channelId = bru.getVar("EXTERNAL_FUNDING_CHANNEL_ID");
  const ch = channels.find((c) => c.channel_id === channelId);

  if (!ch) {
    console.log(
      `[external-funding-open] node1 does not expose channel ${channelId} yet before submit_signed_funding_tx`,
    );
    return;
  }

  const stateName = ch.state && ch.state.state_name;
  const stateFlags = ch.state && ch.state.state_flags;
  if (
    stateName !== "NegotiatingFunding" ||
    typeof stateFlags !== "string" ||
    !stateFlags.split(/[|,]/).map((flag) => flag.trim()).includes("AwaitingExternalFunding")
  ) {
    throw new Error(
      `Assertion failed: expected node1 channel ${channelId} to be NegotiatingFunding(AwaitingExternalFunding) before submit, got ${String(stateName)} / ${String(stateFlags)}`,
    );
  }
}
