meta {
  name: wait channel ready between node1 and node3
  type: http
  seq: 6
}

post {
  url: {{NODE1_RPC_URL}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "id": "42",
    "jsonrpc": "2.0",
    "method": "list_channels",
    "params": [
      {
        "pubkey": "{{NODE3_PUBKEY}}"
      }
    ]
  }
}

vars:post-response {
  max_iterations: 20
}

script:pre-request {
  if (bru.getVar("channel_ready_wait_iteration") === undefined) {
    bru.setVar("channel_ready_wait_iteration", 0);
  }
}

assert {
  res.status: eq 200
}

script:post-response {
  const axios = require("axios");
  const status = bru.getVar("EXTERNAL_FUNDING_SUBMIT_STATUS");
  if (status !== "submitted") {
    console.log(
      `[external-funding-open] skip wait channel ready because submit status is ${String(status)}`,
    );
    return;
  }
  if (bru.getVar("FUNDING_TX_COMMITTED") !== "true") {
    throw new Error("Assertion failed: funding tx is not committed before waiting channel ready");
  }

  const i = bru.getVar("channel_ready_wait_iteration");
  const n = bru.getVar("max_iterations");
  const channels = (res.body && res.body.result && res.body.result.channels) || [];
  const channelId = bru.getVar("EXTERNAL_FUNDING_CHANNEL_ID");
  const ch = channels.find((c) => c.channel_id === channelId);
  const stateName = ch && ch.state && ch.state.state_name;

  if (stateName === "ChannelReady" || stateName === "CHANNEL_READY") {
    const node3Resp = await axios.post(
      bru.getEnvVar("NODE3_RPC_URL"),
      {
        id: "external-funding-node3-ready-check",
        jsonrpc: "2.0",
        method: "list_channels",
        params: [{ pubkey: bru.getEnvVar("NODE1_PUBKEY") }],
      },
      {
        headers: { "Content-Type": "application/json", Accept: "application/json" },
      },
    );

    if (node3Resp.data && node3Resp.data.error) {
      throw new Error(
        `Assertion failed: node3 list_channels failed while checking ready state: ${node3Resp.data.error.message}`,
      );
    }

    const node3Channels = (node3Resp.data && node3Resp.data.result && node3Resp.data.result.channels) || [];
    const node3Channel = node3Channels.find((item) => item.channel_id === channelId);
    const node3State = node3Channel && node3Channel.state && node3Channel.state.state_name;

    if (node3Channel && (node3State === "CHANNEL_READY" || node3State === "ChannelReady")) {
      bru.setVar("channel_ready_wait_iteration", 0);
      console.log(`[external-funding-open] channel is ready on node1 and node3: ${channelId}`);
      return;
    }
  }

  if (i + 1 < n) {
    console.log(
      `[external-funding-open] waiting ChannelReady, retry ${i + 1}/${n}, current_state=${String(stateName)}`,
    );
    bru.setVar("channel_ready_wait_iteration", i + 1);
    await new Promise((r) => setTimeout(r, 1500));
    bru.setNextRequest("wait channel ready between node1 and node3");
    return;
  }

  throw new Error(
    `Assertion failed: channel not ready after ${n} checks, channel_id=${channelId}, last_state=${String(stateName)}`,
  );
}
